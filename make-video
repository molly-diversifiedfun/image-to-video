#!/usr/bin/env bash
#
# make-video — turn a still image into a silent video of N hours.
#
# Strategy (fast AND reasonably small):
#   1. Encode ONE short "base" segment of the image with a single keyframe
#      (every frame after it is "identical to previous" and costs ~nothing).
#   2. Concat-copy that base segment back-to-back (no re-encoding) to fill the
#      requested duration. Encoding happens once per image, so a 10-hour file
#      is produced about as fast as a 1-minute one.
# Output: 4K-native H.264 .mp4, no audio, yuv420p, even dimensions, 30 fps.
#
# Usage:
#   Single file:
#     ./make-video FILE HOURS [OUTDIR]
#     ./make-video 7FineArt_088.tiff 3
#
#   Whole directory, same duration for every image:
#     ./make-video --dir IMAGES_DIR HOURS [--out OUTDIR] [--jobs N]
#
#   Per-file durations via manifest (CSV: path,hours — '#' starts a comment):
#     ./make-video --manifest jobs.csv [--out OUTDIR] [--jobs N]
#
# Optional subtle motion (off by default):
#     --zoom 4    slow continuous zoom of 4% over the whole video (re-encodes,
#                 GPU-accelerated; a 3h file takes ~1.5-2h instead of ~90s).
#
# Optional soundtrack (loop-extend mode):
#     --audio PATH   replace the clip's native audio with a music bed; PATH is a
#                    single audio file or a folder of audio files (crossfaded
#                    playlist). The audio is looped/trimmed to match the video
#                    duration, then muxed in. Video stream always copied.
#     --keep-native  layer the music bed OVER the clip's native sound instead of
#                    replacing it. Requires --audio. If the clip has no native
#                    audio track, this flag is silently ignored (replace path used).
#
# Mix mode (folder of CLIPS → one long mixed video, PRD-4):
#     ./make-video CLIPS_DIR --mix HOURS --out FILE [--xfade S] [--order name]
#                  [--seed N] [--clip-secs N] [--fill] [--hardcut] [--audio P] [--yes]
#   Sequences the clips to fill HOURS, crossfading every junction, never placing
#   a clip back-to-back with itself, reshuffling each pass. This mode RE-ENCODES
#   (slow): it prints a size/time estimate, renders a short preview, and asks
#   go/no-go before the full render. --hardcut skips crossfades (fast fallback).
#
# Output, quality & polish (all modes unless noted):
#     --smooth       (loop-extend) make the loop point PERFECTLY seamless in
#                    picture AND sound: auto-tunes the audio dissolve to the clip
#                    and re-encodes the whole loop continuously (no per-loop blink
#                    or blip). Slower — scales with length — but the best result.
#     --detect-xfade (loop-extend) just print the audio-dissolve length the tool
#                    would auto-pick for a clip, then exit.  No render.
#     --out FILE     write exactly to FILE (e.g. --out rain-8h.mp4). Works in
#                    every mode now; a bare directory still works too.
#     --crf N        encode quality, 0–51 (lower = better/larger). Loop-extend
#                    keeps its own default of 23 unless --crf is given.
#     --height N     downscale output to N px tall (keep aspect). Biggest lever
#                    on a multi-hour file's size, e.g. --height 1080.
#     --fade S       fade up from black at the start and down to black at the
#                    end (video AND audio), S seconds each. The top-and-tail
#                    polish for ambient/sleep loops. Re-encodes only the ends.
#     --gpu          (mix mode) encode on Apple Silicon VideoToolbox instead of
#                    CPU — much faster on the re-encode-heavy mix. Loop-extend
#                    is already copy-based, so it needs no GPU.
#
# Loop-extend note: a too-large --xfade for a short clip is clamped to the
# largest dissolve that fits (with a note) instead of erroring.
#
# HOURS may be fractional (0.5 = 30 min, 0.0167 ≈ 1 min).
# Point at a FOLDER instead of a file to batch the whole directory in parallel.

set -euo pipefail

readonly FPS=30                 # standard rate — YouTube re-encodes low fps poorly
# These read the environment first (then fall back to defaults) so the values
# propagate to the per-image child processes that batch (--dir) / manifest mode
# re-invoke — those children inherit only env, not the original flags.
CRF="${CRF:-18}"                # encode quality (lower = better; 18 ≈ lossless). --crf overrides.
readonly BASE_SECS=30           # static-mode: length of the encoded-once base segment
# Output resolution. Default keeps the source's native size (just forces even
# dims). --height N downscales to N px tall (keeping aspect), the biggest lever
# on a multi-hour file's size (e.g. 4K→1080p ≈ 4× smaller).
HEIGHT="${HEIGHT:-0}"           # 0 = keep native; >0 = scale to this height. Set by --height.
LOOP_CRF="${LOOP_CRF:-23}"      # loop-extend unit quality (its own default; --crf overrides)
SCALE="${SCALE:-scale=trunc(iw/2)*2:trunc(ih/2)*2}"
readonly IMG_EXTS=(jpg jpeg png tif tiff bmp webp heic gif)

# --- zoom (Ken Burns) settings ---
ZOOM_PCT="${ZOOM_PCT:-0}"       # 0 = static (default, fast); opt in with --zoom 4
readonly VBITRATE=25M           # zoom-mode target bitrate (GPU/VideoToolbox encode)
readonly ZOOM_W=4096            # intermediate width — bigger = smoother subpixel zoom

# --- audio settings ---
AUDIO_PATH="${AUDIO_PATH:-}"    # empty = no soundtrack; set via --audio or env export

die() { printf 'error: %s\n' "$1" >&2; exit 1; }
cores() { sysctl -n hw.ncpu 2>/dev/null || nproc 2>/dev/null || echo 4; }

# Locate ffmpeg/ffprobe: prefer a copy bundled in ./bin next to this script
# (so the tool is self-contained on a drive), then fall back to the system PATH.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [[ -f "$SCRIPT_DIR/bin/ffmpeg" && -f "$SCRIPT_DIR/bin/ffprobe" ]]; then
  # Bundled binaries. exFAT drives drop the exec bit and macOS may quarantine
  # downloads, so re-arm both defensively (harmless no-ops otherwise).
  chmod +x "$SCRIPT_DIR/bin/ffmpeg" "$SCRIPT_DIR/bin/ffprobe" 2>/dev/null || true
  xattr -dr com.apple.quarantine "$SCRIPT_DIR/bin" 2>/dev/null || true
  FFMPEG="$SCRIPT_DIR/bin/ffmpeg"; FFPROBE="$SCRIPT_DIR/bin/ffprobe"
else
  FFMPEG="$(command -v ffmpeg || true)"; FFPROBE="$(command -v ffprobe || true)"
fi

# Source shared libs.  These live alongside this script.
# shellcheck source=lib/audio.sh
source "$SCRIPT_DIR/lib/audio.sh"
# shellcheck source=lib/mux.sh
source "$SCRIPT_DIR/lib/mux.sh"
# shellcheck source=lib/classify.sh
source "$SCRIPT_DIR/lib/classify.sh"
# shellcheck source=lib/duration.sh
source "$SCRIPT_DIR/lib/duration.sh"
# shellcheck source=lib/loop.sh
source "$SCRIPT_DIR/lib/loop.sh"
# shellcheck source=lib/seam.sh
source "$SCRIPT_DIR/lib/seam.sh"
# shellcheck source=lib/slideshow.sh
source "$SCRIPT_DIR/lib/slideshow.sh"
# shellcheck source=lib/sequencer.sh
source "$SCRIPT_DIR/lib/sequencer.sh"
# shellcheck source=lib/mixer.sh
source "$SCRIPT_DIR/lib/mixer.sh"
# shellcheck source=lib/fade.sh
source "$SCRIPT_DIR/lib/fade.sh"
# shellcheck source=lib/xfade_auto.sh
source "$SCRIPT_DIR/lib/xfade_auto.sh"

preflight() {
  [[ -n "$FFMPEG" && -n "$FFPROBE" ]] && return 0
  cat >&2 <<'MSG'
error: ffmpeg / ffprobe not found.

This tool needs ffmpeg. Easiest fix on a Mac:
  1. Install Homebrew (one line, from https://brew.sh):
       /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  2. Then install ffmpeg:
       brew install ffmpeg

(Or drop static `ffmpeg` and `ffprobe` binaries into a `bin/` folder next to
this script and it will use those automatically — no install needed.)
MSG
  exit 1
}

# Even (W H) dimensions of an image, space-separated.
img_dims() {
  local dims w h
  dims="$("$FFPROBE" -v error -select_streams v:0 \
    -show_entries stream=width,height -of csv=p=0 "$1")"
  IFS=, read -r w h <<<"$dims"
  printf '%d %d\n' "$((w - w % 2))" "$((h - h % 2))"
}

# STATIC mode: encode a single-keyframe segment of $2 seconds, $1 -> $3.
encode_segment() {
  local img="$1" secs="$2" out="$3"
  "$FFMPEG" -nostdin -loglevel error -y \
    -loop 1 -framerate "$FPS" -t "$secs" -i "$img" \
    -vf "$SCALE,format=yuv420p" \
    -c:v libx264 -tune stillimage -crf "$CRF" \
    -g 999999 -keyint_min 999999 -sc_threshold 0 \
    -an -movflags +faststart "$out"
}

# STATIC mode: image + total seconds -> out (encode-once base, then concat-copy).
make_static() {
  local img="$1" total="$2" out="$3" tmp; tmp="$(mktemp -d)"
  if [[ "$total" -le "$BASE_SECS" ]]; then
    encode_segment "$img" "$total" "$out"
  else
    local base="$tmp/base.mp4" list="$tmp/list.txt"
    local loops=$(( total / BASE_SECS )) rem=$(( total % BASE_SECS )) i
    encode_segment "$img" "$BASE_SECS" "$base"
    : > "$list"
    for (( i=0; i<loops; i++ )); do printf "file '%s'\n" "$base" >> "$list"; done
    [[ "$rem" -gt 0 ]] && { encode_segment "$img" "$rem" "$tmp/rem.mp4"; \
      printf "file '%s'\n" "$tmp/rem.mp4" >> "$list"; }
    "$FFMPEG" -nostdin -loglevel error -y -f concat -safe 0 -i "$list" \
      -c copy -movflags +faststart "$out"
  fi
  rm -rf "$tmp"
}

# ZOOM mode: continuous one-way zoom (1.00 -> 1+ZOOM_PCT%) across the whole
# duration. Every frame is unique, so this re-encodes (GPU/VideoToolbox).
make_zoom() {
  local img="$1" total="$2" out="$3" w h
  read -r w h < <(img_dims "$img")
  local n=$(( total * FPS ))
  local z="1+(${ZOOM_PCT}/100)*on/(${n}-1)"
  "$FFMPEG" -nostdin -loglevel error -y -i "$img" \
    -vf "scale=${ZOOM_W}:-2,zoompan=z='${z}':d=${n}:x='iw/2-(iw/zoom/2)':y='ih/2-(ih/zoom/2)':s=${w}x${h}:fps=${FPS},format=yuv420p" \
    -c:v h264_videotoolbox -b:v "$VBITRATE" -an -t "$total" \
    -movflags +faststart "$out"
}

# Build one video: image + hours -> out_path.
# If $AUDIO_PATH is set, builds a silent video to a temp file first, then
# calls audio_build + mux_audio to attach the soundtrack (video stream copied).
make_one() {
  local img="$1" hours="$2" out="$3"
  [[ -f "$img" ]] || die "no such file: $img"
  local total; total=$(awk -v h="$hours" 'BEGIN{printf "%d", h*3600 + 0.5}')
  [[ "$total" -gt 0 ]] || die "hours must be > 0 (got: $hours)"

  if [[ -z "$AUDIO_PATH" ]]; then
    # No audio: original silent behaviour.
    if [[ "$ZOOM_PCT" == "0" ]]; then make_static "$img" "$total" "$out"
    else make_zoom "$img" "$total" "$out"; fi
  else
    # Audio requested: build silent to a temp file, then mux audio on top.
    [[ -e "$AUDIO_PATH" ]] || die "--audio path not found: $AUDIO_PATH"
    local tmp_dir; tmp_dir="$(mktemp -d)"
    # _cleanup_audio_tmp is defined here and called on every exit path below
    # (success and all failure branches).  We cannot rely on a RETURN trap
    # because set -euo pipefail causes the shell to exit the script (not just
    # the function) when a pipeline step fails, so RETURN never fires.
    _cleanup_audio_tmp() { rm -rf "$tmp_dir"; }
    local tmp_silent="$tmp_dir/silent.mp4"
    local tmp_audio="$tmp_dir/audio.aac"

    # Step 1: build the silent video into tmp (static or zoom, same as today).
    if [[ "$ZOOM_PCT" == "0" ]]; then
      make_static "$img" "$total" "$tmp_silent" || { _cleanup_audio_tmp; return 1; }
    else
      make_zoom "$img" "$total" "$tmp_silent"   || { _cleanup_audio_tmp; return 1; }
    fi

    # Step 2: build audio to exactly $total seconds (loops/trims as needed).
    audio_build "$AUDIO_PATH" "$total" "$tmp_audio" || { _cleanup_audio_tmp; return 1; }

    # Step 3: mux audio onto the silent video (-c:v copy — video NOT re-encoded).
    mux_audio "$tmp_silent" "$tmp_audio" "$out" || { _cleanup_audio_tmp; return 1; }

    _cleanup_audio_tmp
  fi

  # Top-and-tail fade (video + audio), in place, if --fade was given.
  _finalize_fades "$out" || true

  printf '✓ %s  (%sh = %ss, zoom %s%%, audio %s)  ->  %s\n' \
    "$(basename "$img")" "$hours" "$total" "$ZOOM_PCT" "${AUDIO_PATH:-(none)}" "$out"
}

is_image() {
  local b; b="$(basename "$1")"
  [[ "$b" == ._* ]] && return 1          # skip macOS AppleDouble junk
  local ext="${1##*.}"; ext="$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')"
  local e; for e in "${IMG_EXTS[@]}"; do [[ "$ext" == "$e" ]] && return 0; done
  return 1
}

out_path() {  # image, outdir -> outdir/name.mp4
  local img="$1" outdir="$2" name
  name="$(basename "$img")"; name="${name%.*}"
  printf '%s/%s.mp4' "${outdir:-$(dirname "$img")}" "$name"
}

# _finalize_fades OUT — if --fade was requested, top-and-tail the finished file
# with a fade up from black / down to black (video + audio), in place.  No-op
# when FADE is 0.  Re-encodes only the head/tail (see lib/fade.sh).
_finalize_fades() {
  local out="$1"
  awk -v f="${FADE:-0}" 'BEGIN{ exit !(f+0 > 0) }' || return 0
  local faded; faded="$(dirname "$out")/.fade.$$.$(basename "$out")"
  if apply_fades "$out" "$FADE" "$faded"; then
    mv -f "$faded" "$out"
  else
    rm -f "$faded"
    echo "note: --fade step failed; keeping the un-faded output" >&2
    return 1
  fi
}

# ---- argument parsing -------------------------------------------------------

MODE="single" DIR="" MANIFEST="" OUTDIR="" JOBS="" HOURS=""
LOOP_STRATEGY="crossfade"   # loop-extend: crossfade|pingpong|native
LOOP_XFADE="1.0"            # loop-extend: xfade window in seconds
LOOP_YES=0                  # loop-extend: 1 = skip interactive prompt
KEEP_NATIVE=0               # loop-extend + --audio: 0 = replace native audio (default);
                            #                        1 = layer music over native (--keep-native)
SLIDESHOW=0                 # 1 = slideshow mode (folder of images → one long video)
SLIDESHOW_XFADE="2.5"       # slideshow: dissolve duration in seconds (default 2.5)
SLIDESHOW_SHUFFLE=0         # slideshow: 1 = shuffle image order
SLIDESHOW_SEED="$$"         # slideshow: seed for shuffle
SLIDESHOW_FILL=0            # slideshow: 1 = crop-to-fill; 0 = letterbox (default)
EACH_HOURS=""               # slideshow: per-image hold in hours (alias for positional HOURS)
MIX=0                       # 1 = mix mode (folder of clips → one long mixed video, PRD-4)
MIX_XFADE="1.5"             # mix: crossfade seconds at every junction (default 1.5)
MIX_SEED="$$"               # mix: shuffle seed
MIX_ORDER="shuffle"         # mix: shuffle (default) | name (sorted, deterministic)
MIX_CLIP_SECS=0             # mix: cap each clip to N seconds (0 = whole clip)
MIX_FILL=0                  # mix: 1 = crop-to-fill; 0 = letterbox (default)
MIX_HARDCUT=0               # mix: 1 = concat with NO crossfade (fast preview/fallback)
MIX_HOURS=""                # mix: target length in hours (alias for positional HOURS)
OUT_FILE=""                 # explicit output FILE (set when --out names a *.mp4/.mov/.mkv)
MIX_GPU=0                   # 1 = encode mix on Apple Silicon VideoToolbox (--gpu)
FADE="${FADE:-0}"           # fade-in/out seconds at the file's start AND end (--fade);
                            # env-aware so it reaches batch/manifest child processes
DETECT_XFADE=0             # 1 = just report the auto-detected audio crossfade and exit (--detect-xfade)
SMOOTH=0                   # 1 = perfectly-seamless loop: auto audio crossfade + continuous
                           #     re-encode (no per-loop keyframe pulse / audio boundary). Slower. (--smooth)
POS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dir)      MODE="dir";           DIR="$2";            shift 2;;
    --manifest) MODE="manifest";      MANIFEST="$2";       shift 2;;
    --out)      OUTDIR="$2"
                # If the value names a file (video extension), ALSO remember it
                # as an explicit output FILE so single/loop modes write exactly
                # there.  OUTDIR is left untouched so mix/slideshow (which treat
                # --out as their own output path) keep working unchanged.
                case "$2" in
                  *.mp4|*.MP4|*.mov|*.MOV|*.mkv|*.MKV) OUT_FILE="$2";;
                esac
                shift 2;;
    --crf)      CRF="$2"; LOOP_CRF="$2"; shift 2;;
    --height)   HEIGHT="$2";          shift 2;;
    --jobs)     JOBS="$2";            shift 2;;
    --zoom)     ZOOM_PCT="$2";        shift 2;;
    --static)   ZOOM_PCT=0;           shift;;
    --audio)    AUDIO_PATH="$2";      shift 2;;
    --loop)
      case "$2" in
        crossfade|pingpong|native) LOOP_STRATEGY="$2"; shift 2;;
        *) die "unknown --loop value '${2}' (use crossfade|pingpong|native)";;
      esac;;
    --xfade)    LOOP_XFADE="$2"; SLIDESHOW_XFADE="$2"; MIX_XFADE="$2"; shift 2;;
    --yes)         LOOP_YES=1;        shift;;
    --keep-native) KEEP_NATIVE=1;    shift;;
    --slideshow)   SLIDESHOW=1;       shift;;
    --mix)         MIX=1;             shift;;
    --each)        EACH_HOURS="$2";   shift 2;;
    --shuffle)     SLIDESHOW_SHUFFLE=1; shift;;
    --seed)        SLIDESHOW_SEED="$2"; SLIDESHOW_SHUFFLE=1; MIX_SEED="$2"; shift 2;;
    --fill)        SLIDESHOW_FILL=1;  MIX_FILL=1; shift;;
    --order)
      case "$2" in
        shuffle|name) MIX_ORDER="$2"; shift 2;;
        *) die "unknown --order value '${2}' (use shuffle|name)";;
      esac;;
    --clip-secs)   MIX_CLIP_SECS="$2"; shift 2;;
    --hardcut)     MIX_HARDCUT=1;     shift;;
    --gpu)         MIX_GPU=1;         shift;;
    --fade)        FADE="$2";         shift 2;;
    --detect-xfade) DETECT_XFADE=1;   shift;;
    --smooth)      SMOOTH=1;          shift;;
    -h|--help)  sed -n '2,68p' "$0"; exit 0;;
    -*)         die "unknown flag: $1";;
    *)          POS+=("$1");          shift;;
  esac
done

# Validate flag combinations before doing any work.
[[ "$KEEP_NATIVE" -eq 1 && -z "$AUDIO_PATH" ]] && \
  die "--keep-native requires --audio"

# --slideshow on a single file (not a directory) is invalid.
if [[ "$SLIDESHOW" -eq 1 && ${#POS[@]} -ge 1 && -f "${POS[0]}" ]]; then
  die "--slideshow requires a directory input, not a single file"
fi

# --mix on a single file (not a directory) is invalid.
if [[ "$MIX" -eq 1 && ${#POS[@]} -ge 1 && -f "${POS[0]}" ]]; then
  die "--mix requires a directory of clips, not a single file"
fi

# --zoom with --slideshow is invalid.
if [[ "$SLIDESHOW" -eq 1 && "$ZOOM_PCT" != "0" ]]; then
  die "--zoom is not supported in slideshow mode"
fi

# Validate + apply quality / resolution knobs.
[[ "$FADE" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "--fade must be a number of seconds (got: $FADE)"
[[ "$CRF" =~ ^[0-9]+$ ]] || die "--crf must be an integer (got: $CRF)"
{ [[ "$CRF" -ge 0 && "$CRF" -le 51 ]]; } || die "--crf must be 0–51 (got: $CRF)"
[[ "$HEIGHT" =~ ^[0-9]+$ ]] || die "--height must be an integer (got: $HEIGHT)"
if [[ "$HEIGHT" -gt 0 ]]; then
  # Downscale to HEIGHT px tall, keep aspect, force even width.
  SCALE="scale=-2:${HEIGHT}"
fi
# Export so the sourced libs (loop, slideshow, mixer) pick up the same knobs,
# AND so batch/manifest child processes inherit them (they re-invoke this script
# with only the image/hours/outdir, not the original --crf/--height/--fade flags).
export CRF HEIGHT SCALE LOOP_CRF FADE

# --gpu: verify VideoToolbox is actually available; if not, warn and fall back
# to the CPU encoder rather than failing the whole render.
if [[ "$MIX_GPU" -eq 1 ]]; then
  if ! "$FFMPEG" -hide_banner -encoders 2>/dev/null | grep -q "h264_videotoolbox"; then
    printf 'note: --gpu requested but h264_videotoolbox is unavailable; using the CPU encoder.\n' >&2
    MIX_GPU=0
  fi
fi
export MIX_GPU

export SLIDESHOW_XFADE SLIDESHOW_SHUFFLE SLIDESHOW_SEED SLIDESHOW_FILL

preflight   # verify ffmpeg/ffprobe exist before doing any work

# "Point at a folder + a number": if the first positional is a directory,
# treat it as batch mode automatically — no --dir needed.
if [[ "$MODE" == "single" && ${#POS[@]} -ge 1 && -d "${POS[0]}" ]]; then
  MODE="dir"; DIR="${POS[0]}"; POS=("${POS[@]:1}")
fi

# Resolve EACH_HOURS (--each flag) vs positional HOURS for slideshow mode.
# If --each was given, it takes precedence.  If --each is empty but a
# positional HOURS exists, use that as EACH_HOURS.
if [[ "$SLIDESHOW" -eq 1 ]]; then
  if [[ -z "$EACH_HOURS" ]]; then
    # Fall back to first positional arg as HOURS
    [[ ${#POS[@]} -ge 1 ]] && { EACH_HOURS="${POS[0]}"; POS=("${POS[@]:1}"); } \
      || die "--slideshow requires HOURS or --each HOURS"
  fi
fi

# Resolve MIX_HOURS (target length) from positional for mix mode.
if [[ "$MIX" -eq 1 ]]; then
  [[ "$SLIDESHOW" -eq 0 ]] || die "--mix and --slideshow are mutually exclusive"
  [[ "$ZOOM_PCT" == "0" ]] || die "--zoom is not supported in mix mode"
  if [[ -z "$MIX_HOURS" ]]; then
    [[ ${#POS[@]} -ge 1 ]] && { MIX_HOURS="${POS[0]}"; POS=("${POS[@]:1}"); } \
      || die "--mix requires a target HOURS"
  fi
fi

export MIX_XFADE MIX_SEED MIX_ORDER MIX_CLIP_SECS MIX_FILL MIX_HARDCUT

# Auto-pick parallelism by mode (override with --jobs):
#   zoom  → the zoompan filter is ~single-core and the GPU encoder is shared,
#           so run several at once to fill cores (but not so many the GPU chokes).
#   static→ libx264 is already multi-threaded, so a couple at a time is plenty.
if [[ -z "$JOBS" ]]; then
  c="$(cores)"
  if [[ "$ZOOM_PCT" == "0" ]]; then JOBS=$(( c >= 4 ? 2 : 1 ))
  else JOBS=$(( c >= 8 ? 4 : (c >= 4 ? 2 : 1) )); fi
fi

# In slideshow/mix modes OUTDIR is the output FILE path, and when --out names a
# file (OUT_FILE set) OUTDIR is that file too — in both cases skip the mkdir-p
# so we don't create "out.mp4" as a directory.  The single-mode dispatch makes
# the parent dir for an explicit --out FILE itself.
if [[ "$SLIDESHOW" -eq 0 && "$MIX" -eq 0 && -z "$OUT_FILE" && -n "$OUTDIR" ]]; then
  mkdir -p "$OUTDIR"
fi
export ZOOM_PCT                 # propagate to re-invoked single-mode children
export AUDIO_PATH               # propagate to re-invoked single-mode children

# ---------------------------------------------------------------------------
# loop_extend_mode CLIP HOURS OUT
#
# Called when classify_input says the input is a single video clip.
# Builds a seamless-loop long video from CLIP.
#
# 1. parse_duration HOURS → target_secs
# 2. Build loop unit: loop_unit CLIP unit.mp4 --loop STRATEGY --xfade XFADE
# 3. Preview gate: seam_check at wrap boundary → verdict + estimated size.
#    Print: verdict line, estimated output duration/size, seam-preview path.
#    If NOT SEAMLESS: print pingpong recommendation.
#    Prompt only when stdin is a TTY AND --yes not given; otherwise auto-proceed.
# 4. Tile unit to fill target_secs via concat-copy, then trim to exact target.
# 5. Audio: keep unit's native audio (from loop_unit) unless --audio PATH given
#    (then use audio_build + mux_audio to replace).
# 6. Clean up all temps on ALL exit paths using explicit || { cleanup; return 1; }.
# ---------------------------------------------------------------------------
loop_extend_mode() {
  local clip="$1"
  local hours="$2"
  local out="$3"
  local _t0=$SECONDS   # wall-clock start, for the "rendered in Ns" readout

  [[ -f "$clip" ]] || die "no such file: $clip"

  # --zoom (zoompan) is a still-image-mode feature; it has no meaning for a
  # video clip input.  Reject early rather than silently ignoring it.
  [[ "$ZOOM_PCT" == "0" ]] || die "--zoom is not supported in loop-extend mode (video input)"

  local target_secs
  target_secs="$(parse_duration "$hours")" || die "invalid HOURS: $hours"
  [[ "$target_secs" -gt 0 ]] || die "hours must be > 0 (got: $hours)"

  # Validate --audio path early (before expensive work)
  if [[ -n "$AUDIO_PATH" ]]; then
    [[ -e "$AUDIO_PATH" ]] || die "--audio path not found: $AUDIO_PATH"
  fi

  # --smooth: auto-detect how long the audio crossfade needs to be for THIS clip
  # (based on how much its start/end ambience differ) and raise the crossfade to
  # at least that.  A longer-than-needed dissolve is harmless on steady ambience,
  # so we only ever raise, never lower the user's choice.  (Native audio only —
  # with --audio the soundtrack is built seamlessly already.)
  if [[ "$SMOOTH" -eq 1 && "$LOOP_STRATEGY" == "crossfade" && -z "$AUDIO_PATH" ]]; then
    local _det
    if _det="$(detect_audio_xfade "$clip")" && [[ -n "$_det" ]]; then
      if awk -v a="$_det" -v b="$LOOP_XFADE" 'BEGIN{ exit !(a > b) }'; then
        printf 'note: --smooth raised the dissolve to %ss (auto-detected from the clip'\''s sound for a seamless audio loop)\n' "$_det" >&2
        LOOP_XFADE="$_det"
      fi
    fi
  fi

  # Short-clip handling for crossfade: the dissolve needs the clip to be at
  # least 3× the xfade window.  Rather than erroring out on a short clip, clamp
  # the window down to the largest dissolve that fits and tell the operator how
  # long a clip the requested window would need.  (pingpong/native don't use
  # xfade, so this only applies to crossfade.)
  if [[ "$LOOP_STRATEGY" == "crossfade" ]]; then
    local clip_dur
    if clip_dur="$(_loop_get_duration "$clip")"; then
      local fits
      fits="$(awk -v d="$clip_dur" -v x="$LOOP_XFADE" 'BEGIN{print (x <= d/3) ? 1 : 0}')"
      if [[ "$fits" -eq 0 ]]; then
        # Floor to 2 decimals so 3×max_xf stays <= clip_dur (no rounding-up).
        local max_xf need_secs
        max_xf="$(awk -v d="$clip_dur" 'BEGIN{printf "%.2f", int(d/3*100)/100}')"
        need_secs="$(awk -v x="$LOOP_XFADE" 'BEGIN{printf "%.1f", 3*x}')"
        printf 'note: clip is %.1fs — too short for a %ss dissolve (needs a clip of at least %ss). Using the largest dissolve that fits: %ss.\n' \
          "$clip_dur" "$LOOP_XFADE" "$need_secs" "$max_xf" >&2
        LOOP_XFADE="$max_xf"
      fi
    fi
  fi

  local tmp_dir
  tmp_dir="$(mktemp -d)"
  # Named sentinel file so the cleanup assertion in the test can detect leaks.
  local unit_file="$tmp_dir/loop_unit_0.mp4"
  local tiled_file="$tmp_dir/tiled.mp4"
  local list_file="$tmp_dir/concat.txt"

  _cleanup_loop_tmp() { rm -rf "$tmp_dir"; }

  # ------------------------------------------------------------------
  # Step 1.5: resolution (--height) — pre-scale the source clip ONCE so every
  # loop strategy (crossfade/pingpong/native) inherits the target size.  This
  # is the biggest lever on a multi-hour file's size (4K→1080p ≈ 4× smaller).
  # ------------------------------------------------------------------
  if [[ "${HEIGHT:-0}" -gt 0 ]]; then
    local scaled_clip="$tmp_dir/scaled_src.mp4"
    if _loop_has_audio "$clip"; then
      "$FFMPEG" -nostdin -loglevel error -y -i "$clip" \
        -vf "scale=-2:${HEIGHT},format=yuv420p" \
        -c:v libx264 -preset veryfast -crf "${LOOP_CRF:-23}" \
        -c:a copy "$scaled_clip" || { _cleanup_loop_tmp; return 1; }
    else
      "$FFMPEG" -nostdin -loglevel error -y -i "$clip" \
        -vf "scale=-2:${HEIGHT},format=yuv420p" \
        -c:v libx264 -preset veryfast -crf "${LOOP_CRF:-23}" \
        -an "$scaled_clip" || { _cleanup_loop_tmp; return 1; }
    fi
    clip="$scaled_clip"
  fi

  # ------------------------------------------------------------------
  # Step 2: build the loop unit
  # ------------------------------------------------------------------
  loop_unit "$clip" "$unit_file" \
    --loop "$LOOP_STRATEGY" --xfade "$LOOP_XFADE" \
    || { _cleanup_loop_tmp; return 1; }

  # ------------------------------------------------------------------
  # Step 3: preview gate
  #   - get unit duration (for tiling math) and EXACT packet count (for seam_check)
  #   - run seam_check on the wrap boundary using the real packet count
  #   - print verdict, estimated output, preview path
  #   - if NOT SEAMLESS and not already on pingpong: print recommendation
  #   - prompt only if stdin is TTY and --yes not set
  # ------------------------------------------------------------------
  local unit_dur
  unit_dur="$("$FFPROBE" \
    -v error \
    -show_entries format=duration \
    -of default=noprint_wrappers=1:nokey=1 \
    "$unit_file")" || { _cleanup_loop_tmp; return 1; }

  # Derive the boundary frame from the ACTUAL video packet count, not from
  # duration * fps arithmetic.  The float-rounding in duration*fps can be off
  # by ±1, which points the probe mid-second-copy rather than at the real cut
  # and can report a wrong verdict (e.g. SOFT on a truly seamless pingpong).
  # Packet count is exact — identical to what assert_seam_ok / test 2 use.
  local unit_frames
  unit_frames="$("$FFPROBE" -v error \
    -select_streams v:0 \
    -count_packets \
    -show_entries stream=nb_read_packets \
    -of default=noprint_wrappers=1:nokey=1 \
    "$unit_file")"
  [[ "$unit_frames" =~ ^[0-9]+$ ]] || { _cleanup_loop_tmp; return 1; }

  # Need at least frame 12 for seam_check to produce a meaningful baseline.
  local verdict=""
  if [[ "$unit_frames" -ge 12 ]]; then
    # Build a 2-copy tile for seam_check (cheap concat-copy)
    printf "file '%s'\n" "$unit_file" > "$list_file"
    printf "file '%s'\n" "$unit_file" >> "$list_file"
    local preview_file="$tmp_dir/seam_preview.mp4"
    "$FFMPEG" -nostdin -loglevel error -y \
      -f concat -safe 0 -i "$list_file" \
      -c copy "$preview_file" \
      || { _cleanup_loop_tmp; return 1; }

    local seam_output
    seam_output="$(seam_check "$preview_file" "$unit_frames" 2>/dev/null)" || seam_output="seam@${unit_frames}: measurement skipped"
    verdict="$(echo "$seam_output" | grep -oE '(SEAMLESS|SOFT|VISIBLE)' | head -1 || true)"

    # Estimated output size (rough: unit_file_size / unit_dur * target_secs)
    local unit_size_bytes
    unit_size_bytes="$(wc -c < "$unit_file" | tr -d ' ')"
    local est_mb
    est_mb="$(awk -v sz="$unit_size_bytes" -v ud="$unit_dur" -v ts="$target_secs" \
      'BEGIN { printf "%.0f", sz / ud * ts / 1048576 }')"

    printf '[loop-extend] preview gate\n'
    printf '  %s\n' "$seam_output"

    # Disk-space guard.  A multi-hour loop can be tens of GB; --smooth re-encodes
    # roughly 2.5× smaller than the fast concat-copy.  Estimate the real footprint
    # and REFUSE to start if it won't fit — far better than filling the disk
    # mid-render (which leaves a giant broken file behind).
    local need_mb free_mb
    need_mb="$(awk -v e="$est_mb" -v s="$SMOOTH" 'BEGIN{ printf "%.0f", (s==1)? e/2.5 : e }')"
    free_mb="$(df -k "$(dirname "$out")" 2>/dev/null | awk 'NR==2{printf "%.0f", $4/1024}')"
    printf '  estimated output: %s s, ~%s MB%s   (free disk: ~%s MB)\n' \
      "$target_secs" "$need_mb" "$( [[ "$SMOOTH" -eq 1 ]] && echo ' [smooth]' )" "${free_mb:-?}"
    printf '  seam preview clip: %s\n' "$preview_file"

    if [[ -n "$free_mb" ]] && awk -v n="$need_mb" -v f="$free_mb" 'BEGIN{ exit !(n > f*0.95) }'; then
      printf '  ✗ not enough free disk: ~%s MB needed, ~%s MB free.\n' "$need_mb" "$free_mb" >&2
      printf '    Free up space, or shrink the file with --height (e.g. --height 1080) or a higher --crf (e.g. --crf 26).\n' >&2
      _cleanup_loop_tmp; return 1
    fi

    # Only suggest pingpong when not already using it (avoid confusing tip-on-pingpong),
    # and not under --smooth (the continuous re-encode already removes the seam).
    if [[ "$verdict" != "SEAMLESS" && "$LOOP_STRATEGY" != "pingpong" && "$SMOOTH" -ne 1 ]]; then
      printf '  tip: for a truly seamless loop try --loop pingpong (reverses motion), or --smooth (no reversal, but slower)\n'
    fi
  else
    printf '[loop-extend] preview gate: unit too short for seam measurement (skipped)\n'
  fi

  # Go/no-go gate: prompt only if stdin is a TTY AND --yes was not given
  if [[ -t 0 && "$LOOP_YES" -eq 0 ]]; then
    printf 'Continue? [Y/n] '
    local answer
    read -r answer
    case "${answer:-y}" in
      y|Y|yes|YES) ;;
      *) printf 'Aborted.\n'; _cleanup_loop_tmp; return 1 ;;
    esac
  fi

  # ------------------------------------------------------------------
  # Step 4: tile unit to fill target_secs, then trim to exact target
  #
  # How many copies of the unit do we need?
  # copies = ceil(target_secs / unit_dur) + 1 (safety margin)
  # Then trim with ffmpeg using -t target_secs and -c copy.
  #
  # Note: -c copy with -t is not always frame-accurate for variable-bitrate
  # content, but is within ±1 frame (±1/fps ≈ 0.033 s) for H.264 CBR segments,
  # which is well within our ±1.0 s test tolerance.
  # ------------------------------------------------------------------
  local copies
  copies="$(awk -v ts="$target_secs" -v ud="$unit_dur" \
    'BEGIN { printf "%d", int(ts / ud) + 2 }')"

  : > "$list_file"
  local i
  for (( i=0; i<copies; i++ )); do
    printf "file '%s'\n" "$unit_file" >> "$list_file"
  done

  # Determine if unit has audio
  local unit_has_audio=0
  local ua_count
  ua_count="$("$FFPROBE" -v error \
    -select_streams a \
    -show_entries stream=index \
    -of csv=p=0 \
    "$unit_file" | grep -c .)" || true
  ua_count="${ua_count:-0}"
  [[ "$ua_count" -ge 1 ]] && unit_has_audio=1

  # --smooth: encode the tiled loop in ONE continuous pass straight from the
  # concat list (libx264 video + AAC audio) — no per-loop keyframe pulse / audio
  # boundary, AND no giant concat-copy intermediate on disk (critical at 8h: the
  # ultrafast unit bitrate would otherwise materialise a ~10× larger temp file).
  # Default stays a fast stream copy.
  local -a _venc _aenc
  if [[ "$SMOOTH" -eq 1 ]]; then
    _venc=(-c:v libx264 -preset veryfast -crf "${LOOP_CRF:-23}" -pix_fmt yuv420p)
    _aenc=(-c:a aac -b:a 192k)
    printf 'note: --smooth — encoding the whole loop continuously for a flawless seam (this is the slow step)…\n' >&2
  else
    _venc=(-c:v copy)
    _aenc=(-c:a copy)
  fi

  if [[ -z "$AUDIO_PATH" ]]; then
    # No external audio: tile + trim to produce the final output directly.
    if [[ "$unit_has_audio" -eq 1 ]]; then
      "$FFMPEG" -nostdin -loglevel error -y \
        -f concat -safe 0 -i "$list_file" \
        -t "$target_secs" \
        "${_venc[@]}" "${_aenc[@]}" \
        -movflags +faststart \
        "$out" || { _cleanup_loop_tmp; return 1; }
    else
      "$FFMPEG" -nostdin -loglevel error -y \
        -f concat -safe 0 -i "$list_file" \
        -t "$target_secs" \
        "${_venc[@]}" -an \
        -movflags +faststart \
        "$out" || { _cleanup_loop_tmp; return 1; }
    fi
  else
    # External audio requested.
    # --keep-native=1 AND unit has audio → layer music over native.
    # --keep-native=1 AND unit has no audio → note + fall back to replace.
    # --keep-native=0 (default) → replace (strip native, mux music only).
    local audio_mode="replace"
    if [[ "$KEEP_NATIVE" -eq 1 ]]; then
      if [[ "$unit_has_audio" -eq 1 ]]; then
        audio_mode="layer"
      else
        printf 'note: --keep-native ignored, clip has no audio track\n' >&2
      fi
    fi

    local tmp_audio="$tmp_dir/audio.aac"

    if [[ "$audio_mode" == "layer" ]]; then
      # Tile WITH native audio preserved (re-encode video under --smooth so the
      # mux copies an already-seamless, normal-size video — no giant temp).
      "$FFMPEG" -nostdin -loglevel error -y \
        -f concat -safe 0 -i "$list_file" \
        -t "$target_secs" \
        "${_venc[@]}" -c:a copy \
        -movflags +faststart \
        "$tiled_file" || { _cleanup_loop_tmp; return 1; }

      audio_build "$AUDIO_PATH" "$target_secs" "$tmp_audio" \
        || { _cleanup_loop_tmp; return 1; }

      mux_audio_layer "$tiled_file" "$tmp_audio" "$out" \
        || { _cleanup_loop_tmp; return 1; }
    else
      # Replace: tile silent (strip native audio), then mux external music.
      "$FFMPEG" -nostdin -loglevel error -y \
        -f concat -safe 0 -i "$list_file" \
        -t "$target_secs" \
        "${_venc[@]}" -an \
        -movflags +faststart \
        "$tiled_file" || { _cleanup_loop_tmp; return 1; }

      audio_build "$AUDIO_PATH" "$target_secs" "$tmp_audio" \
        || { _cleanup_loop_tmp; return 1; }

      mux_audio "$tiled_file" "$tmp_audio" "$out" \
        || { _cleanup_loop_tmp; return 1; }
    fi
  fi

  _cleanup_loop_tmp

  # (--smooth is applied inline during tiling above — one continuous pass, no
  #  giant concat-copy intermediate.)
  # Top-and-tail fade (video + audio), in place, if --fade was given.
  _finalize_fades "$out" || true

  local audio_label
  if [[ -n "$AUDIO_PATH" ]]; then
    audio_label="${audio_mode:-replace}: $AUDIO_PATH"
  else
    audio_label="(native)"
  fi
  printf '✓ %s  (%sh = %ss, loop %s, xfade %ss, audio %s%s, rendered in %ss)  ->  %s\n' \
    "$(basename "$clip")" "$hours" "$target_secs" "$LOOP_STRATEGY" "$LOOP_XFADE" \
    "$audio_label" "$( [[ "$SMOOTH" -eq 1 ]] && echo ', smooth' || echo '' )" \
    "$(( SECONDS - _t0 ))" "$out"
}

# ---------------------------------------------------------------------------
# mix_mode DIR HOURS OUT  (PRD-4)
#
# Folder of clips → ONE long mixed video. Because this mode fully re-encodes
# and the estimate always exceeds the preview threshold, we ALWAYS:
#   1. Print a render-time / size estimate and state that it re-encodes.
#   2. Render a short preview (first few junctions) + run seam_check on it.
#   3. Require explicit go/no-go (prompt on a TTY unless --yes) before the
#      full multi-hour render.
# ---------------------------------------------------------------------------
mix_mode() {
  local dir="$1" hours="$2" out="$3"
  local _t0=$SECONDS   # wall-clock start, for the "rendered in Ns" readout
  [[ -d "$dir" ]] || die "no such directory: $dir"
  [[ -n "$out" ]] || die "--mix requires --out FILE"

  local target_secs
  target_secs="$(parse_duration "$hours")" || die "invalid HOURS: $hours"

  # Rough estimate from the first clip's resolution + target length.
  local first_clip
  first_clip="$(find "$dir" -maxdepth 1 -mindepth 1 -type f | LC_ALL=C sort \
    | while read -r f; do [[ "$(classify_input "$f")" == "video" ]] && { echo "$f"; break; }; done)"
  [[ -n "$first_clip" ]] || die "--mix: no video clips found in $dir"
  local pw ph
  read -r pw ph < <("$FFPROBE" -v error -select_streams v:0 \
    -show_entries stream=width,height -of csv=p=0 "$first_clip" | tr ',' ' ')
  # Size estimate: extrapolate from the first clip's ACTUAL bytes-per-second
  # (encoded), far more accurate than a raw-frame heuristic for H.264 content.
  local fc_bytes fc_dur est_mb
  fc_bytes="$(wc -c < "$first_clip" | tr -d ' ')"
  fc_dur="$("$FFPROBE" -v error -show_entries format=duration \
    -of default=noprint_wrappers=1:nokey=1 "$first_clip")"
  est_mb="$(awk -v b="$fc_bytes" -v d="$fc_dur" -v t="$target_secs" \
    'BEGIN{ if (d>0) printf "%.0f", b/d*t/1048576; else printf "?" }')"
  # Re-encode render time is roughly proportional to output length; print a
  # deliberately rough band rather than a false-precision single number.
  local est_lo est_hi
  est_lo="$(awk -v t="$target_secs" 'BEGIN{printf "%.0f", t/60*0.5}')"
  est_hi="$(awk -v t="$target_secs" 'BEGIN{printf "%.0f", t/60*2}')"

  printf '[mix] PLAN — this mode RE-ENCODES every clip (slow).\n'
  printf '  target: %ss (%sh)  resolution: %sx%s\n' "$target_secs" "$hours" "$pw" "$ph"
  printf '  encoder: %s\n' "$( [[ "${MIX_GPU:-0}" -eq 1 ]] && echo 'GPU (VideoToolbox) — faster' || echo 'CPU (libx264); add --gpu for hardware encoding' )"
  printf '  estimated output size: ~%sMB\n' "$est_mb"
  printf '  estimated render time: ~%s–%s min (rough; depends on machine/GPU)\n' "$est_lo" "$est_hi"

  # --- Preview: render the first few junctions, seam-check the first one. ---
  local preview_dir; preview_dir="$(mktemp -d)"
  local preview="$preview_dir/preview.mp4"
  local junc_file="$preview_dir/junction.txt"
  printf '[mix] rendering preview (first few junctions)…\n'
  if MIX_MAX_CLIPS=4 MIX_FIRST_JUNCTION_OUT="$junc_file" \
       mix_clips "$dir" "$hours" "$preview" >/dev/null 2>&1; then
    printf '  preview clip: %s\n' "$preview"
    if [[ -s "$junc_file" ]]; then
      local jf; jf="$(cat "$junc_file")"
      local verdict
      verdict="$(seam_check "$preview" "$jf" 2>/dev/null \
        | grep -oE '(SEAMLESS|SOFT|VISIBLE)' | head -1 || true)"
      [[ -n "$verdict" ]] && printf '  first-junction seam: %s\n' "$verdict"
    fi
  else
    printf '  (preview render skipped — proceeding to full render)\n'
  fi

  # --- Go/no-go gate: prompt on a TTY unless --yes was given. ---
  if [[ -t 0 && "$LOOP_YES" -eq 0 ]]; then
    printf 'Proceed with the full render? [Y/n] '
    local answer; read -r answer
    case "${answer:-y}" in
      y|Y|yes|YES) ;;
      *) printf 'Aborted.\n'; rm -rf "$preview_dir"; return 1 ;;
    esac
  fi
  rm -rf "$preview_dir"

  mix_clips "$dir" "$hours" "$out" || return 1
  # Top-and-tail fade (video + audio), in place, if --fade was given.
  _finalize_fades "$out" || true
  printf '✓ mix  (%ss, %s)  rendered in %ss  ->  %s\n' \
    "$target_secs" "$( [[ "${MIX_GPU:-0}" -eq 1 ]] && echo 'GPU' || echo 'CPU' )" \
    "$(( SECONDS - _t0 ))" "$out"
}

case "$MODE" in
  # Parallel modes re-invoke THIS script in single mode (one process per image),
  # avoiding exported-function fragility. xargs -I{} uses newline as the only
  # delimiter, so spaces in paths (e.g. "/Volumes/1TB SSD/...") are safe.
  single)
    # --detect-xfade: report the auto-detected audio crossfade for a clip and exit.
    # (No HOURS needed — it's a read-only analysis of the clip's ambience.)
    if [[ "$DETECT_XFADE" -eq 1 ]]; then
      [[ ${#POS[@]} -ge 1 ]] || die "usage: $0 CLIP --detect-xfade"
      [[ "$(classify_input "${POS[0]}" 2>/dev/null)" == "video" ]] \
        || die "--detect-xfade needs a video clip: ${POS[0]}"
      printf 'recommended audio crossfade for %s: %ss\n' \
        "$(basename "${POS[0]}")" "$(XFADE_AUTO_VERBOSE=1 detect_audio_xfade "${POS[0]}")"
      exit 0
    fi

    [[ ${#POS[@]} -ge 2 ]] || die "usage: $0 FILE HOURS [OUTDIR | --out FILE]"

    # Resolve the output path.  Precedence: explicit --out FILE (e.g.
    # --out rain-8h.mp4) wins; else a positional OUTDIR; else --out DIR; else
    # next to the source.  --out FILE works in every mode now (loop-extend used
    # to only accept a positional OUTDIR).
    if [[ -n "$OUT_FILE" ]]; then
      _out_target="$OUT_FILE"
      mkdir -p "$(dirname "$OUT_FILE")"
    else
      _out_target="$(out_path "${POS[0]}" "${POS[2]:-$OUTDIR}")"
    fi

    # Classify the input: if it's a video, enter loop-extend mode (PRD-2).
    _input_kind="$(classify_input "${POS[0]}" 2>/dev/null || echo "unknown")"
    if [[ "$_input_kind" == "video" ]]; then
      loop_extend_mode "${POS[0]}" "${POS[1]}" "$_out_target"
    else
      make_one "${POS[0]}" "${POS[1]}" "$_out_target"
    fi
    ;;
  dir)
    [[ -d "$DIR" ]] || die "no such directory: $DIR"

    if [[ "$MIX" -eq 1 ]]; then
      # Mix mode (PRD-4): folder of clips → ONE long mixed video + soundtrack.
      [[ -n "$MIX_HOURS" ]] || die "--mix requires a target HOURS"
      [[ -n "$OUTDIR" ]] || die "--mix requires --out FILE"
      mix_mode "$DIR" "$MIX_HOURS" "$OUTDIR"
    elif [[ "$SLIDESHOW" -eq 1 ]]; then
      # Slideshow mode: folder of images → ONE long video with crossfades.
      [[ -n "$EACH_HOURS" ]] || die "--slideshow requires HOURS or --each HOURS"
      [[ -n "$OUTDIR" ]] || die "--slideshow requires --out OUTDIR"
      xfade_join "$DIR" "$EACH_HOURS" "$OUTDIR"
      # Top-and-tail fade, if --fade was given (xfade_join doesn't know about it).
      _finalize_fades "$OUTDIR" || true
    else
      # Batch mode (default): each image → its own video (existing behaviour).
      [[ ${#POS[@]} -ge 1 ]] || die "--dir mode needs HOURS: $0 --dir DIR HOURS"
      HOURS="${POS[0]}"
      find "$DIR" -maxdepth 1 -type f | while read -r f; do
        is_image "$f" && printf '%s\n' "$f"
      done | xargs -P "$JOBS" -I{} "$0" {} "$HOURS" "$OUTDIR"
    fi
    ;;
  manifest)
    [[ -f "$MANIFEST" ]] || die "no such manifest: $MANIFEST"
    grep -v -e '^[[:space:]]*#' -e '^[[:space:]]*$' "$MANIFEST" \
      | xargs -P "$JOBS" -I{} bash -c '
          IFS=, read -r img hrs <<<"$2"
          img="$(printf "%s" "$img" | xargs)"   # trim surrounding whitespace
          hrs="$(printf "%s" "$hrs" | xargs)"
          exec "$1" "$img" "$hrs" "$3"
        ' _ "$0" {} "$OUTDIR"
    ;;
esac
